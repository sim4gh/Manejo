float4 getColorFromCell(int2 cellId, float2 position, float4 color) {
	for (int i = 0; i < _MaxDropletsInCell; ++i) {
		float size = OutBuffer[GetDropId(cellId, i)].size;
		if (size <= 0) break;
		float2 vec = position.xy - OutBuffer[GetDropId(cellId, i)].position;
		float dist = length(vec);
		if (dist <= size && dist <= _MaxDropletSize) {
			return float4(1, 1, 1, 1);
		}
	}
	return color;
}

float4 getColorFromNeighbourCells(int2 id) {
	float2 cellSize = PixelCellSize();
	int2 cellId = int2(id.x / cellSize.x, id.y / cellSize.y);
	float2 posInCell = float2(float(id.x) % cellSize.x, float(id.y) % cellSize.y);
	int sideX = (posInCell.x >= (cellSize.x / 2)) ? 1 : -1;
	int sideY = (posInCell.y >= (cellSize.y / 2)) ? 1 : -1;

	float2 position = UVToPos(id.xy);

	float4 color = float4(0, 0, 0, 0);
	color = getColorFromCell(cellId, position, color);
	int2 neighbour1 = cellId + int2(sideX, 0);
	if (isCellInBounds(neighbour1)) {
		color = getColorFromCell(neighbour1, position, color);
	}
	int2 neighbour2 = cellId + int2(0, sideY);
	if (isCellInBounds(neighbour2)) {
		color = getColorFromCell(neighbour2, position, color);
	}
	int2 neighbour3 = cellId + int2(sideX, sideY);
	if (isCellInBounds(neighbour3)) {
		color = getColorFromCell(neighbour3, position, color);
	}
	return color;
}

[numthreads(THREAD_SIZE, THREAD_SIZE,1)]
void CSToTexture(uint3 id : SV_DispatchThreadID)
{
	float4 color = getColorFromNeighbourCells(id.xy);

	float4 prevState = PrevState[id.xy].rgba;
	prevState = prevState * clamp(1 - _RainStreakDecayRate * _DeltaTime, 0, 1);
	color += prevState;

	color = float4(clamp(color.x, 0, 1), clamp(color.y, 0, 1), clamp(color.z, 0, 1), clamp(color.a, 0, 1));


#if WIPERS_ENABLED
	if (WipersTexture[id.xy].z > _WipersThreshold) {
		Result[id.xy] = float4(0, 0, 0, color.a);
		return;
	}
#endif
	Result[id.xy] = float4(color);
}


[numthreads(THREAD_SIZE, THREAD_SIZE, 1)]
void CSInitTextures(uint3 id : SV_DispatchThreadID)
{
	PrevState[id.xy] = float4(0, 0, 0, 0);
	Result[id.xy] = float4(0, 0, 0, 0);
}

