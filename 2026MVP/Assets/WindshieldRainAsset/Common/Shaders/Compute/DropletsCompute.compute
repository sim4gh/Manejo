int getDropsFromNeighbourCell(int2 cellId, int2 neighbourCellId, int dropsCount) {

	for (int i = 0; i < MAX_DROPLETS_IN_CELL; ++i) {
		if (InBuffer[Cells2dId(neighbourCellId)].drops[i].size <= 0) break;
		if (isInCurrentCell(cellId, InBuffer[Cells2dId(neighbourCellId)].drops[i].position)) {
			OutBuffer[Cells2dId(cellId)].drops[dropsCount].velocity = InBuffer[Cells2dId(neighbourCellId)].drops[i].velocity;
			OutBuffer[Cells2dId(cellId)].drops[dropsCount].position = InBuffer[Cells2dId(neighbourCellId)].drops[i].position;
			OutBuffer[Cells2dId(cellId)].drops[dropsCount].size = InBuffer[Cells2dId(neighbourCellId)].drops[i].size;
			dropsCount++;
			if (dropsCount >= MAX_DROPLETS_IN_CELL) return dropsCount;
		}
	}
	return dropsCount;
}

void getDropsFromAllNeighbourCells(int2 cellId, int dropsCount) {
	for (int i = 0; i < 9; ++i) {
		int x = (i % 3) - 1;
		int y = (i / 3) - 1;
		if (x == 0 && y == 0) continue;
		int2 neighbourId = cellId.xy + int2(x, y);
		if (!isCellInBounds(neighbourId)) continue;
		dropsCount = getDropsFromNeighbourCell(cellId, neighbourId, dropsCount);
		if (dropsCount >= MAX_DROPLETS_IN_CELL) return;
	}
}

bool isDropNew_MergeIfNot(int cellId, int dropId, int dropsCount) {
	if (_DropsInfluenceDistance <= 0 && _DropsMergingDistance <= 0) {
		return true;
	}

	for (int j = 0; j < dropsCount; ++j) {
		float distance = length(OutBuffer[cellId].drops[j].position - InBuffer[cellId].drops[dropId].position);
		if (distance < _DropsInfluenceDistance || distance < _DropsMergingDistance) {
			OutBuffer[cellId].drops[j].velocity = (OutBuffer[cellId].drops[j].velocity + InBuffer[cellId].drops[dropId].velocity) * 0.5f;
		}
		if (distance < _DropsMergingDistance) {
			// Merge drops
			OutBuffer[cellId].drops[j].size += InBuffer[cellId].drops[dropId].size * 0.5f;
			OutBuffer[cellId].drops[j].size = min(OutBuffer[cellId].drops[j].size, _MaxPossibleDropletSize);
			return false;
		}
	}
	return true;
}

